rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isValidEmail(s) {
      return s is string && s.matches('^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$') && s.size() < 200;
    }

    function shortString(s, max) {
      return s is string && s.size() > 0 && s.size() <= max;
    }

    match /newsletter/{id} {
      allow read: if false;
      allow create: if request.resource.data.keys().hasOnly(['email', 'source', 'createdAt'])
        && isValidEmail(request.resource.data.email);
      allow update, delete: if false;
    }

    match /brand_submissions/{id} {
      allow read: if false;
      allow create: if shortString(request.resource.data.name, 120)
        && isValidEmail(request.resource.data.email)
        && shortString(request.resource.data.brand, 200)
        && shortString(request.resource.data.category, 60)
        && shortString(request.resource.data.building, 4000);
      allow update, delete: if false;
    }

    match /contact_messages/{id} {
      allow read: if false;
      allow create: if shortString(request.resource.data.name, 120)
        && isValidEmail(request.resource.data.email)
        && shortString(request.resource.data.subject, 200)
        && shortString(request.resource.data.message, 4000);
      allow update, delete: if false;
    }
  }
}
